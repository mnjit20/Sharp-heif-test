    "express": "^4.21.0",
    "jest": "^30.0.0",
    "multer": "^1.4.5-lts.1",
    "node-addon-api": "^8.2.1",
    "node-gyp": "^10.2.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.13"
  }
